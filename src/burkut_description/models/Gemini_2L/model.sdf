<?xml version="1.0" ?>
<sdf version='1.9'>
    <model name='Gemini_2L'>
        <!-- Bu Gemini 2L modeli için bir SDF dosyasıdır. 
             -Özellikler
             aktif stereo IR
             100 mm baseline
             Depth FOV H91° V66° 
             RGB FOV H94° V68° 
             1280×800@30 fps 
             0.2–10 m depth range 
             IMU support

            .sdf dosyasında bulunanlar:
            gemini2l_body → kameranın fiziksel gövdesi
            rgb_camera → renkli görüntü
            left_ir_camera → sol stereo göz
            right_ir_camera → sağ stereo göz
            depth_camera → işlenmiş depth çıktısı
            imu → opsiyonel IMU sensörü 
            -->
        <static>false</static>

        <link name="gemini2l_body">
            <pose>0 0 0 0 0 0</pose>

            <inertial>
                <mass>0.152</mass>
                <inertia>
                    <ixx>1.9215e-05</ixx>
                    <iyy>2.0333e-04</iyy>
                    <izz>2.0542e-04</izz>
                    <ixy>0.0</ixy>
                    <ixz>0.0</ixz>
                    <iyz>0.0</iyz>  
                </inertia>
            </inertial>
            
            <collision name="body_collision">
                <geometry>
                    <box>
                        <size>0.124 0.029 0.026</size>
                    </box>
                </geometry>
            </collision>

            <visual name="body_visual">
                <geometry>
                    <box>
                        <size>0.124 0.029 0.026</size>
                    </box>
                </geometry>
                <material>
                    <ambient>0.1 0.1 0.1 1</ambient>
                    <diffuse>0.15 0.15 0.15 1</diffuse>
                    <specular>0.02 0.02 0.02 1</specular>
                </material>
            </visual>
        
        <!-- RGB Camera -->
        <sensor name="rgb_camera" type="camera">
            <pose>0 0 0 0 0 0</pose>

            <always_on>1</always_on>
            <update_rate>30</update_rate>
            <visualize>false</visualize>

            <topic>/gemini2l/rgb/image_raw</topic>

            <camera name="rgb_camera_sensor">
                <camera_info_topic>gemini2l/rgb/camera_info</camera_info_topic>
                <optical_frame_id>rgb_camera_optical_frame</optical_frame_id>

                <horizontal_fov>1.6406094969</horizontal_fov>

                <image>
                    <width>640</width>
                    <height>480</height>
                    <format>R8G8B8</format>
                </image>

                <clip>
                    <near>0.05</near>
                    <far>20.0</far>
                </clip>

                <intrinsics>
                    <fx>596.8097</fx>
                    <fy>593.0244</fy>
                    <cx>640.0</cx>
                    <cy>400.0</cy>
                    <s>0.0</s>
                </intrinsics>

                <!-- Gerçek kamera versi gelince distortion ekle-->
                
            </camera>
        </sensor>

        <!-- Left IR Camera -->

        <sensor name="left_ir_camera" type="camera">
            <pose>0 0 0 0 0 0</pose>

            <always_on>0</always_on>
            <update_rate>30</update_rate>
            <visualize>false</visualize>

            <topic>/gemini2l/left_ir/image_raw</topic>

            <camera name="left_ir_camera_sensor">
                <camera_info_topic>gemini2l/left_ir/camera_info</camera_info_topic>
                <optical_frame_id>left_ir_camera_optical_frame</optical_frame_id>

                <horizontal_fov>1.588249619</horizontal_fov>

                <image>
                    <width>1280</width>
                    <height>800</height>
                    <format>L8</format>
                </image>

                <clip>
                    <near>0.05</near>
                    <far>20.0</far>
                </clip>
  
                <intrinsics>
                    <fx>628.9262</fx>
                    <fy>615.9460</fy>
                    <cx>640.0</cx>
                    <cy>400.0</cy>
                    <s>0.0</s>
                </intrinsics>

                <projection>
                    <p_fx>628.9262</p_fx>
                    <p_fy>615.9460</p_fy>
                    <p_cx>640.0</p_cx>
                    <p_cy>400.0</p_cy>
                    <tx>0.0</tx>
                    <ty>0.0</ty>
                </projection>
            </camera>
        </sensor>

        <!-- Right IR Camera -->

        <sensor name="right_ir_camera" type="camera">
            <pose>0 0 0 0 0 0</pose>

            <always_on>0</always_on>
            <update_rate>30</update_rate>
            <visualize>false</visualize>
            
            <topic>/gemini2l/right_ir/image_raw</topic>

            <camera name="right_ir_camera_sensor">
                <camera_info_topic>gemini2l/right_ir/camera_info</camera_info_topic>
                <optical_frame_id>right_ir_camera_optical_frame</optical_frame_id>
                
                
                <horizontal_fov>1.588249619</horizontal_fov>

                <image>
                    <width>1280</width>
                    <height>800</height>
                    <format>L8</format>
                </image>
                
                <clip>
                    <near>0.05</near>
                    <far>20.0</far>
                </clip>

                <intrinsics>
                    <fx>628.9262</fx>
                    <fy>615.9460</fy>
                    <cx>640.0</cx>
                    <cy>400.0</cy>
                    <s>0.0</s>
                </intrinsics>

                <projection>
                    <p_fx>628.9262</p_fx>
                    <p_fy>615.9460</p_fy>
                    <p_cx>640.0</p_cx>
                    <p_cy>400.0</p_cy>
                    <tx>-62.8926</tx>
                    <ty>0.0</ty>
                </projection>
            </camera>
        </sensor>
        

        <!-- Depth Camera -->
        <sensor name="depth_camera" type="depth_camera">
        <!--
          Depth çıktısını cihazın "işlenmiş merkezi çıkışı" gibi düşün.
          O yüzden gövde merkezine koyuyoruz.
        -->
        <pose>0 0 0 0 0 0</pose>

        <always_on>false</always_on>
        <update_rate>30</update_rate>
        <visualize>false</visualize>

        <topic>/gemini2l/depth/image_raw</topic>

        <camera name="depth_camera_sensor">
          <camera_info_topic>/gemini2l/depth/camera_info</camera_info_topic>
          <optical_frame_id>gemini2l_depth_optical_frame</optical_frame_id>

          <!-- Depth HFOV = 91 deg -->
          <horizontal_fov>1.5882496193</horizontal_fov>

          <!-- Depth image için float format -->
          <image>
            <width>1280</width>
            <height>800</height>
            <format>R_FLOAT32</format>
          </image>

          <!-- Render clip -->
          <clip>
            <near>0.05</near>
            <far>20.0</far>
          </clip>

          <!--
            Depth sensörünün ölçüm aralığı:
            resmi aralık 0.2 - 10.0 m
          -->
          <depth_camera>
            <output>depths</output>
            <clip>
              <near>0.2</near>
              <far>10.0</far>
            </clip>
          </depth_camera>

          <intrinsics>
            <fx>628.9262</fx>
            <fy>615.9460</fy>
            <cx>640.0</cx>
            <cy>400.0</cy>
            <s>0.0</s>
          </intrinsics>

          <noise>
            <type>gaussian</type>
            <mean>0.0</mean>
            <stddev>0.002</stddev>
          </noise>
          
        </camera>
      </sensor>
    </link>
  </model>
</sdf>
