      <child>left_wing</child>
    </joint>

    <!-- ELEVATOR -->
   <link name="elevator">
    <pose relative_to="base_link">-0.61897 0 9.7e-04 0 0 0</pose>
    <inertial>
      <pose>0 0 0 0 0 0</pose>
      <mass>0.150</mass>
      <inertia>
        <ixx>7.145483e-03</ixx>
