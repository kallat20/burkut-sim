        </geometry>
        <material>
          <ambient>0.25 0.88 0.82 1.0</ambient>
          <diffuse>0.25 0.88 0.82 1.0</diffuse>
        </material>
      </visual>
      <gravity>1</gravity>
      <velocity_decay />
      <self_collide>0</self_collide>
    </link>
    <joint name="right_wing_joint" type="fixed">
      <parent>base_link</parent>
      <child>right_wing</child>
    </joint>

    <!-- Sol Kanat -->
    <link name="left_wing">
      <pose relative_to="base_link">-0.049295 0.348685 -2.107e-03 0 0 0</pose>
      <inertial>
        <pose>0 0 0 0 0 0</pose>
        <mass>0.40</mass>
        <inertia>
          <ixx>0.026351893</ixx>
