<?xml version="1.0" ?>
<launch>

    <!--Parametreler-->

    <arg name="world" default="test"/>
    <arg name="plane" default="burkut"/>
    <arg name="airframe_id" default="4008"/>
    <arg name="instance" default="0"/>
    
    <!--Spawn -->
    <arg name = "x" default="-44.65"/>
    <arg name = "y" default="9.75"/>
    <arg name = "z" default="2.2"/>
    <arg name = "roll" default="0"/>
    <arg name = "pitch" default="0"/>
    <arg name = "yaw" default="0"/>
    <arg name = "headless" default="false"/>

    <!-- ===== GZ_SIM_RESOURCE_PATH ===== -->
    <append_env name="GZ_SIM_RESOURCE_PATH"
                value="$(find-pkg-share burkut_worlds)/worlds"/>
    <append_env name="GZ_SIM_RESOURCE_PATH"
                value="$(find-pkg-share burkut_description)/models"/>

    <!-- ===== 1. Gazebo Harmonic ===== -->
    <include file="$(find-pkg-share ros_gz_sim)/launch/gz_sim.launch.py">
        <arg name="gz_args"
             value="-r $(find-pkg-share burkut_worlds)/worlds/$(var world).sdf"/>
    </include>

    <!-- ===== 2. Burkut Test spawn ===== -->
    <node pkg="ros_gz_sim"
          exec="create"
          name="spawn_burkut_test_sbt"
          output="screen"
          args="-name $(var plane)
                -x $(var x) -y $(var y) -z $(var z)
                -R $(var roll) -P $(var pitch) -Y $(var yaw)
                -file $(find-pkg-share burkut_description)/models/BURKUT_montaj/model.sdf">
    </node>

    <!-- ===== 2.1. Katapult spawn ===== -->
    <node pkg="ros_gz_sim"
          exec="create"
          name="spawn_katapult"
          output="screen"
          args="-name katapult
                -x -45 -y 10 -z 0
                -R 0 -P 0 -Y 0
                -file $(find-pkg-share burkut_description)/models/katapult/model.sdf">
    </node>
    <!-- ===== 3. Clock Bridge ===== -->
    <node pkg="ros_gz_bridge"
          exec="parameter_bridge"
          name="bridge_clock"
          output="screen"
          args="/clock@rosgraph_msgs/msg/Clock[gz.msgs.Clock">
    </node>

    <!-- ===== 3.1. Kamera Bridge ===== -->
    <node pkg="ros_gz_bridge"
          exec="parameter_bridge"
          name="bridge_camera"
          output="screen"
          args="/camera/image_raw@sensor_msgs/msg/Image[gz.msgs.Image
                /camera/camera_info@sensor_msgs/msg/CameraInfo[gz.msgs.CameraInfo">
    </node>

    <!-- ===== 3.2. Lidar Bridge ===== -->
    <node pkg="ros_gz_bridge"
          exec="parameter_bridge"
          name="bridge_lidar"
          output="screen"
          args="/lidar/scan@sensor_msgs/msg/LaserScan[gz.msgs.LaserScan">
    </node>

    <!-- ===== 3.3. IMU / Barometer / Manyetometre / GPS Bridge ===== -->
    <node pkg="ros_gz_bridge"
          exec="parameter_bridge"
          name="bridge_flight_sensors"
          output="screen"
          args="/model/burkut/link/base_link/sensor/imu_sensor/imu@sensor_msgs/msg/Imu[gz.msgs.IMU
                /model/burkut/link/base_link/sensor/air_pressure_sensor/air_pressure@sensor_msgs/msg/FluidPressure[gz.msgs.FluidPressure
                /model/burkut/link/base_link/sensor/magnetometer_sensor/magnetometer@sensor_msgs/msg/MagneticField[gz.msgs.Magnetometer
                /model/burkut/link/base_link/sensor/navsat_sensor/navsat@sensor_msgs/msg/NavSatFix[gz.msgs.NavSat">
    </node>

    <!-- ===== 3.4. TF Bridge ===== -->
    <node pkg="ros_gz_bridge"
          exec="parameter_bridge"
          name="bridge_tf"
          output="screen"
          args="/model/burkut/pose@tf2_msgs/msg/TFMessage[gz.msgs.Pose_V">
        <remap from="/model/burkut/pose" to="/tf"/>
    </node>

    <!-- ===== 4. Rviz2 ===== -->
    <node pkg="rviz2"
          exec="rviz2"
          name="rviz2"
          output="screen">
        <param name="use_sim_time" value="true"/>
    </node>

</launch>